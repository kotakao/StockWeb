@page "/stock/{Code}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<PageTitle>個股 @Code</PageTitle>

@if (_quotes is null && _loadError is null)
{
    <p class="card-reason">載入中…</p>
}
else if (_loadError is not null)
{
    <h1>個股 @Code</h1>
    <p class="error">無法載入：@_loadError</p>
}
else if (_notFound)
{
    <h1>查無代號 @Code</h1>
    <p class="card-reason">資料庫沒有此股票代號的行情紀錄。請確認代號是否正確，或改由<a href="screener">條件選股</a>／<a href="watchlist">自選股</a>進入。</p>
}
else
{
    <div class="stock-header">
        <h1>@_quotes!.Code @_quotes.Name</h1>
        @if (MarketLabel is not null)
        {
            <span class="stock-market">@MarketLabel</span>
        }
    </div>

    <div class="metric-cards">
        @foreach (var m in BuildMetrics())
        {
            <div class="metric-card @(m.MissingReason is null ? null : "metric-missing")"
                 title="@(m.MissingReason ?? m.Label)">
                <div class="metric-label">@m.Label</div>
                <div class="metric-value">@m.Display</div>
                <div class="metric-asof">@(m.AsOf ?? "—")</div>
            </div>
        }
    </div>

    @if (_dividends is { Count: > 0 })
    {
        <div class="stock-dividends">
            @foreach (var ev in _dividends)
            {
                <span class="ev">@ev.ExDate @DividendLabel(ev)</span>
            }
        </div>
    }

    <div class="stock-toolbar">
        <div class="period-switch">
            @foreach (var (value, label) in Periods)
            {
                <button type="button" class="@(_period == value ? "active" : null)"
                        @onclick="() => SetPeriodAsync(value)" disabled="@_quotesBusy">@label</button>
            }
        </div>
        <label>
            <input type="checkbox" checked="@_adjusted" @onchange="ToggleAdjustedAsync" disabled="@_quotesBusy" />
            還原價（前復權）
        </label>
        @if (_quotesBusy)
        {
            <span class="card-reason">切換中…</span>
        }
    </div>

    <div class="stock-charts">
        <section class="card">
            <h2>@PeriodLabel K 線（@(_adjusted ? "還原價" : "原始價")）</h2>
            @if (BuildCandles() is { } kline)
            {
                <LightweightChart Spec="kline" @key="KlineKey" />
            }
            else
            {
                <p class="card-reason">尚無 K 線資料。</p>
            }
        </section>

        <section class="card">
            <h2>成交量（張）</h2>
            @if (BuildVolume() is { } vol)
            {
                <LightweightChart Spec="vol" @key="VolumeKey" />
            }
            else
            {
                <p class="card-reason">尚無成交量資料。</p>
            }
        </section>

        <section class="card">
            <h2>三大法人買賣超合計（張）</h2>
            @if (BuildInstitutional() is { } inst)
            {
                <LightweightChart Spec="inst" />
            }
            else
            {
                <p class="card-reason">尚無三大法人資料。</p>
            }
        </section>

        <section class="card">
            <h2>融資融券餘額</h2>
            @if (BuildMargin() is { } margin)
            {
                <p class="card-caption">融資 <span class="dot" style="background:#6a1b9a"></span> · 融券 <span class="dot" style="background:#00838f"></span>（右軸融資、左軸融券）</p>
                <LightweightChart Spec="margin" />
            }
            else
            {
                <p class="card-reason">尚無融資券資料。</p>
            }
        </section>
    </div>

    <h2 class="stock-section-title">季度損益</h2>
    <div class="stock-lower">
        <section class="card">
            <h2>季度營收（億元）</h2>
            @if (BuildQuarterlyRevenue() is { } qrev)
            {
                <LightweightChart Spec="qrev" />
            }
            else
            {
                <p class="card-reason">尚無季度損益資料（自部署起累積，多數個股目前僅最新一季）。</p>
            }
        </section>

        <section class="card">
            <h2>季度毛利率／營益率（%）</h2>
            @if (BuildQuarterlyMargins() is { } qmargin)
            {
                <p class="card-caption">毛利率 <span class="dot" style="background:#6a1b9a"></span> · 營益率 <span class="dot" style="background:#00838f"></span></p>
                <LightweightChart Spec="qmargin" />
            }
            else
            {
                <p class="card-reason">尚無季度毛利／營益資料。</p>
            }
        </section>

        <section class="card">
            <h2>季度 EPS（元）</h2>
            @if (BuildQuarterlyEps() is { } qeps)
            {
                <LightweightChart Spec="qeps" />
            }
            else
            {
                <p class="card-reason">尚無季度 EPS 資料。</p>
            }
        </section>
    </div>

    <div class="stock-lower">
        <section class="card">
            <h2>月營收 YoY（%）</h2>
            @if (BuildRevenue() is { } rev)
            {
                <LightweightChart Spec="rev" />
            }
            else
            {
                <p class="card-reason">尚無月營收資料（自部署起累積）。</p>
            }
        </section>

        <section class="card">
            <h2>估值歷史</h2>
            @if (BuildValuation() is { } val)
            {
                <p class="card-caption">本益比 <span class="dot" style="background:#1565c0"></span> · 淨值比 <span class="dot" style="background:#6a1b9a"></span>（右軸）· 殖利率% <span class="dot" style="background:#2e7d32"></span>（左軸）</p>
                <LightweightChart Spec="val" />
            }
            else
            {
                <p class="card-reason">尚無估值資料。</p>
            }
        </section>
    </div>
}

@code {
    [Parameter] public string Code { get; set; } = "";

    private StockQuotesResponse? _quotes;
    private IReadOnlyList<StockInstitutionalRow>? _institutional;
    private IReadOnlyList<StockMarginRow>? _margin;
    private IReadOnlyList<StockValuationRow>? _valuation;
    private IReadOnlyList<StockRevenueRow>? _revenue;
    private IReadOnlyList<StockFinancialRow>? _financials;
    private IReadOnlyList<DividendEvent>? _dividends;

    private bool _adjusted = true;
    private string _period = "daily";
    private bool _notFound;
    private string? _loadError;
    private bool _quotesBusy;
    private string? _loadedCode;   // 已載入的代號，避免同代號重複載入

    private static readonly (string Value, string Label)[] Periods =
    {
        ("daily", "日"), ("weekly", "週"), ("monthly", "月"), ("yearly", "年"),
    };

    private string PeriodLabel => _period switch
    {
        "weekly" => "週", "monthly" => "月", "yearly" => "年", _ => "日",
    };

    // K 線／成交量在還原或週期切換時強制重建（Lightweight 不就地換資料型別）。
    private string KlineKey => $"kline-{_adjusted}-{_period}";
    private string VolumeKey => $"vol-{_adjusted}-{_period}";

    private string? MarketLabel => _quotes?.Market switch
    {
        "TWSE" => "上市",
        "TPEX" => "上櫃",
        null => null,
        var m => m,
    };

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedCode == Code)
            return;
        _loadedCode = Code;
        await LoadAllAsync();
    }

    private HttpClient Client()
    {
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(Nav.BaseUri);
        return client;
    }

    private async Task LoadAllAsync()
    {
        _quotes = null;
        _notFound = false;
        _loadError = null;
        _adjusted = true;
        _period = "daily";

        try
        {
            var client = Client();
            _quotes = await client.GetFromJsonAsync<StockQuotesResponse>(QuotesUrl());

            if (_quotes is null || _quotes.Quotes.Count == 0)
            {
                _notFound = true;
                return;
            }

            // 其餘資料各自容錯：任一失敗不擋整頁（比照 Dashboard 分區容錯）。
            _institutional = await SafeGet<List<StockInstitutionalRow>>(client, $"api/stocks/{Code}/institutional?days=60");
            _margin = await SafeGet<List<StockMarginRow>>(client, $"api/stocks/{Code}/margin?days=60");
            _valuation = await SafeGet<List<StockValuationRow>>(client, $"api/stocks/{Code}/valuation?days=252");
            _revenue = await SafeGet<List<StockRevenueRow>>(client, $"api/stocks/{Code}/revenue?months=24");
            _financials = await SafeGet<List<StockFinancialRow>>(client, $"api/stocks/{Code}/financials?quarters=20");
            _dividends = await SafeGet<List<DividendEvent>>(client, $"api/stocks/{Code}/dividends");
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }

    private string QuotesUrl()
        => $"api/stocks/{Code}/quotes?days=252&adjusted={_adjusted.ToString().ToLowerInvariant()}&period={_period}";

    private static async Task<T?> SafeGet<T>(HttpClient client, string url)
    {
        try
        {
            return await client.GetFromJsonAsync<T>(url);
        }
        catch
        {
            return default;
        }
    }

    private async Task ToggleAdjustedAsync(ChangeEventArgs e)
    {
        _adjusted = e.Value is true;
        await ReloadQuotesAsync();
    }

    private async Task SetPeriodAsync(string period)
    {
        if (_period == period)
            return;
        _period = period;
        await ReloadQuotesAsync();
    }

    // 還原或週期切換僅重抓 K 線；其餘副圖不隨週期改變。
    private async Task ReloadQuotesAsync()
    {
        _quotesBusy = true;
        try
        {
            _quotes = await Client().GetFromJsonAsync<StockQuotesResponse>(QuotesUrl());
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _quotesBusy = false;
        }
    }

    private static string DividendLabel(DividendEvent ev)
    {
        var parts = new List<string>();
        if (ev.CashDividend is > 0)
            parts.Add($"息{ev.CashDividend:0.##}");
        if (ev.StockRatio is > 0)
            parts.Add($"權{ev.StockRatio:0.###}");
        var body = parts.Count > 0 ? string.Join("/", parts) : (ev.EventType ?? "除權息");
        return body;
    }

    // ── 頁首指標卡 ──
    private record Metric(string Label, string Display, string? AsOf, string? MissingReason);

    private IReadOnlyList<Metric> BuildMetrics()
    {
        var v = _valuation is { Count: > 0 } ? _valuation[^1] : null;   // 估值最新日
        var r = _revenue is { Count: > 0 } ? _revenue[^1] : null;      // 月營收最新月
        var f = _financials is { Count: > 0 } ? _financials[^1] : null; // 季損益最新季

        const string valReason = "尚無估值資料";
        const string revReason = "尚無月營收資料（自部署起累積）";
        const string finReason = "尚無季度損益資料";

        return new List<Metric>
        {
            Metric_("本益比", v?.Pe, v?.Date, valReason, x => x.ToString("0.##")),
            Metric_("股價淨值比", v?.Pb, v?.Date, valReason, x => x.ToString("0.##")),
            Metric_("殖利率", v?.DividendYield, v?.Date, valReason, x => $"{x:0.##}%"),
            Metric_("月營收 YoY", r?.YoyPct, r?.YearMonth, revReason, Pct),
            Metric_("累計營收 YoY", r?.CumYoyPct, r?.YearMonth, revReason, Pct),
            Metric_("毛利率", f?.GrossMargin, f?.YearQuarter, finReason, x => $"{x:0.##}%"),
            Metric_("營業利益率", f?.OperatingMargin, f?.YearQuarter, finReason, x => $"{x:0.##}%"),
            Metric_("EPS", f?.Eps, f?.YearQuarter, finReason, x => x.ToString("0.##")),
        };
    }

    // asOf 為 null 代表整個資料來源缺漏；有 asOf 但值為 null 代表該期缺該欄位。兩者皆顯示「—」。
    private static Metric Metric_(string label, double? value, string? asOf, string sourceReason, Func<double, string> format)
    {
        if (asOf is null)
            return new Metric(label, "—", null, sourceReason);
        if (value is null)
            return new Metric(label, "—", asOf, "該期無此欄位資料");
        return new Metric(label, format(value.Value), asOf, null);
    }

    private static string Pct(double v) => $"{v:+0.##;-0.##;0}%";

    private ChartSpec? BuildCandles()
    {
        var candles = _quotes!.Quotes
            .Where(q => q is { Open: not null, High: not null, Low: not null, Close: not null })
            .Select(q => new ChartCandle(q.Date, q.Open!.Value, q.High!.Value, q.Low!.Value, q.Close!.Value))
            .ToList();
        if (candles.Count == 0)
            return null;

        return new ChartSpec(new List<ChartSeries>
        {
            new("candlestick", Array.Empty<ChartPoint>(), Candles: candles),
        }, Height: 320);
    }

    private ChartSpec? BuildVolume()
    {
        var bars = _quotes!.Quotes
            .Where(q => q.Volume is not null)
            .Select(q => new ChartPoint(q.Date, Math.Round(q.Volume!.Value / 1000, 0), UpDownColor(q)))
            .ToList();
        return bars.Count > 0
            ? new ChartSpec(new List<ChartSeries> { new("histogram", bars, Title: "成交量(張)") }, Height: 180)
            : null;
    }

    // 收盤 >= 開盤為漲（紅），否則為跌（綠）；缺值時不上色（沿用序列預設）。
    private static string? UpDownColor(StockQuote q)
        => q is { Open: { } o, Close: { } c }
            ? (c >= o ? "#d32f2f" : "#2e7d32")
            : null;

    private ChartSpec? BuildInstitutional()
    {
        if (_institutional is null || _institutional.Count == 0)
            return null;

        var bars = _institutional
            .Select(r =>
            {
                var net = (r.ForeignNet ?? 0) + (r.TrustNet ?? 0) + (r.DealerNet ?? 0);
                return new ChartPoint(r.Date, Math.Round(net / 1000, 0), net >= 0 ? "#d32f2f" : "#2e7d32");
            })
            .ToList();
        return new ChartSpec(new List<ChartSeries> { new("histogram", bars, Title: "三大法人合計(張)") }, Height: 180);
    }

    private ChartSpec? BuildMargin()
    {
        if (_margin is null || _margin.Count == 0)
            return null;

        var financing = Points(_margin, r => r.MarginBalance);
        var shortSell = Points(_margin, r => r.ShortBalance);
        if (financing.Count == 0 && shortSell.Count == 0)
            return null;

        var series = new List<ChartSeries>();
        if (financing.Count > 0)
            series.Add(new ChartSeries("line", financing, "#6a1b9a", "right", "融資餘額"));
        if (shortSell.Count > 0)
            series.Add(new ChartSeries("line", shortSell, "#00838f", "left", "融券餘額"));
        return new ChartSpec(series, LeftScale: shortSell.Count > 0, Height: 200);
    }

    private ChartSpec? BuildRevenue()
    {
        if (_revenue is null || _revenue.Count == 0)
            return null;

        var bars = _revenue
            .Where(r => r.YoyPct is not null)
            .Select(r => new ChartPoint(RevenueTime(r.YearMonth), r.YoyPct!.Value, r.YoyPct!.Value >= 0 ? "#d32f2f" : "#2e7d32"))
            .ToList();
        return bars.Count > 0
            ? new ChartSpec(new List<ChartSeries> { new("histogram", bars, Title: "月營收YoY(%)") }, Height: 220)
            : null;
    }

    // year_month（YYYY-MM）補上該月第一天，供圖表時間軸使用。
    private static string RevenueTime(string yearMonth)
        => yearMonth.Length == 7 ? $"{yearMonth}-01" : yearMonth;

    // ── 季度損益趨勢 ──
    private ChartSpec? BuildQuarterlyRevenue()
    {
        if (_financials is null || _financials.Count == 0)
            return null;

        // 營收原單位為仟元 → 億元（÷100000）。
        var bars = _financials
            .Where(f => f.Revenue is not null)
            .Select(f => new ChartPoint(QuarterTime(f.YearQuarter), Math.Round(f.Revenue!.Value / 100000, 2), "#1565c0"))
            .ToList();
        return bars.Count > 0
            ? new ChartSpec(new List<ChartSeries> { new("histogram", bars, Title: "營收(億元)") }, Height: 200)
            : null;
    }

    private ChartSpec? BuildQuarterlyMargins()
    {
        if (_financials is null || _financials.Count == 0)
            return null;

        var gross = FinPoints(f => f.GrossMargin);
        var op = FinPoints(f => f.OperatingMargin);
        if (gross.Count == 0 && op.Count == 0)
            return null;

        var series = new List<ChartSeries>();
        if (gross.Count > 0)
            series.Add(new ChartSeries("line", gross, "#6a1b9a", "right", "毛利率%"));
        if (op.Count > 0)
            series.Add(new ChartSeries("line", op, "#00838f", "right", "營益率%"));
        return new ChartSpec(series, Height: 200);
    }

    private ChartSpec? BuildQuarterlyEps()
    {
        if (_financials is null || _financials.Count == 0)
            return null;

        var bars = _financials
            .Where(f => f.Eps is not null)
            .Select(f => new ChartPoint(QuarterTime(f.YearQuarter), f.Eps!.Value, f.Eps!.Value >= 0 ? "#d32f2f" : "#2e7d32"))
            .ToList();
        return bars.Count > 0
            ? new ChartSpec(new List<ChartSeries> { new("histogram", bars, Title: "EPS(元)") }, Height: 200)
            : null;
    }

    private List<ChartPoint> FinPoints(Func<StockFinancialRow, double?> selector)
        => _financials!.Where(f => selector(f) is not null)
                       .Select(f => new ChartPoint(QuarterTime(f.YearQuarter), selector(f)!.Value))
                       .ToList();

    // year_quarter（YYYYQn）→ 該季末日，供圖表時間軸使用；格式不符時原樣回傳。
    private static string QuarterTime(string yearQuarter)
    {
        if (yearQuarter.Length == 6 &&
            int.TryParse(yearQuarter[..4], out var year) &&
            int.TryParse(yearQuarter[5..], out var quarter) && quarter is >= 1 and <= 4)
        {
            var (month, day) = quarter switch { 1 => (3, 31), 2 => (6, 30), 3 => (9, 30), _ => (12, 31) };
            return $"{year:D4}-{month:D2}-{day:D2}";
        }
        return yearQuarter;
    }

    private ChartSpec? BuildValuation()
    {
        if (_valuation is null || _valuation.Count == 0)
            return null;

        var pe = Points(_valuation, r => r.Pe);
        var pb = Points(_valuation, r => r.Pb);
        var yield = Points(_valuation, r => r.DividendYield);
        if (pe.Count == 0 && pb.Count == 0 && yield.Count == 0)
            return null;

        var series = new List<ChartSeries>();
        if (pe.Count > 0)
            series.Add(new ChartSeries("line", pe, "#1565c0", "right", "本益比"));
        if (pb.Count > 0)
            series.Add(new ChartSeries("line", pb, "#6a1b9a", "right", "淨值比"));
        if (yield.Count > 0)
            series.Add(new ChartSeries("line", yield, "#2e7d32", "left", "殖利率%"));
        return new ChartSpec(series, LeftScale: yield.Count > 0, Height: 220);
    }

    private static List<ChartPoint> Points(IReadOnlyList<StockValuationRow> rows, Func<StockValuationRow, double?> selector)
        => rows.Where(r => selector(r) is not null)
               .Select(r => new ChartPoint(r.Date, selector(r)!.Value))
               .ToList();

    private static List<ChartPoint> Points(IReadOnlyList<StockMarginRow> rows, Func<StockMarginRow, double?> selector)
        => rows.Where(r => selector(r) is not null)
               .Select(r => new ChartPoint(r.Date, selector(r)!.Value))
               .ToList();
}
